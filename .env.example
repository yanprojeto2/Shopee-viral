# Neon PostgreSQL — copie de: console.neon.tech → seu projeto → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Auth — gere com: openssl rand -base64 32
AUTH_SECRET=sua_chave_secreta_aqui

# Credenciais do admin (defina antes de rodar o seed)
ADMIN_EMAIL=admin@shopee-viral.com
ADMIN_PASSWORD=Admin@2024

# Vercel Blob — obtenha em: vercel.com → Storage → Blob → Create Store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
